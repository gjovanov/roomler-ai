{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roomler",
  "version": "0.3.0-rc.30",
  "identifier": "ai.roomler.agent-tray",
  "build": {
    "frontendDist": "src/front",
    "devUrl": "http://localhost:1430"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false
    },
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Roomler",
        "width": 1100,
        "height": 740,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "app"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Roomler desktop",
    "longDescription": "Desktop control surface for the Roomler device service: device overview, network peers with live connection types, daemon-supervised tunnel routes with live throughput, onboarding, settings, and remote-control consent prompts.",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
